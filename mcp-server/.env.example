# Core Supabase access
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Optional override if the REST API base differs from the default Supabase Functions URL
CASHPILOT_API_BASE=https://your-project-ref.supabase.co/functions/v1/api-v1

# REST API tests
CASHPILOT_TEST_API_KEY=replace-with-valid-api-key

# Password-based test accounts
TEST_SCTE_EMAIL=scte.test@cashpilot.cloud
TEST_SCTE_PASSWORD=replace-with-current-password
TEST_FREELANCE_EMAIL=freelance.test@cashpilot.cloud
TEST_FREELANCE_PASSWORD=replace-with-current-password

# Optional: only if an admin has been bootstrapped server-side in public.user_roles
TEST_ADMIN_EMAIL=replace-with-real-admin@example.com
TEST_ADMIN_PASSWORD=replace-with-admin-password
