VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key-here
VITE_SENTRY_DSN=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
VITE_SENTRY_ENABLE_DEV=false
VITE_APP_RELEASE=

# Edge Function runtime configuration (server-side)
APP_URL=https://cashpilot.tech
APP_ORIGIN=https://cashpilot.tech
SIGNATURE_EVIDENCE_SECRET=replace-with-strong-random-secret
GOCARDLESS_SECRET_ID=
GOCARDLESS_SECRET_KEY=

# Stripe (required for full webhook smoke verification)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
SMOKE_STRIPE_MODE=full

# Xero OAuth
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=
XERO_SCOPES=offline_access accounting.transactions accounting.contacts accounting.settings

# QuickBooks OAuth
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REDIRECT_URI=
QUICKBOOKS_SCOPES=com.intuit.quickbooks.accounting
