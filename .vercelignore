# ============================================================
# .vercelignore — Only deploy files needed for the Vite build
# ============================================================

# Dependencies (Vercel installs from package.json)
node_modules/
.npm/

# Build artifacts (Vercel builds fresh)
/dist/
/coverage/
.cache/
.vite/

# Git and local tooling
.git/
.github/
.husky/
.vscode/
.worktrees/
.claude/

# Environment files
.env
.env.*
!.env.example

# Temp files
/artifacts/
/tmp_generated_tool_names.txt
*.log
*.tmp
AGENTS.md

# ---- Non-runtime directories (docs, plans, archives) ----
# Anchored with / to avoid matching src/components/peppol/ etc.
/Agents SaaS/
/Analyse Comptable Et Financière/
/Analyse Stratégique/
/Audit/
/Bank Connection/
/CashPilot Presentation/
/Context/
/Demo/
/Exigences CashPilot/
/Fonctionnalités/
/Gestion Ressources Humaines Et Matérielles/
/KIMI K2.5 - CASHPILOT/
/Landing Page Infos/
/Payments/
/Peppol/
/Plans-Implémentation/
/Plugin CashPilot/
/Pricing/
/System-State/
/task-to-do/
/Tests/
/Updates/
/Vérification Implémentations/
/docs/

# ---- Backend / SQL (deployed separately via Supabase) ----
/mcp-server/
/migrations/
/supabase/

# ---- Other non-runtime directories ----
# Anchored with / to avoid matching src/components/api/ etc.
/api/
/n8n-workflows/
/skills/
/stripe/
